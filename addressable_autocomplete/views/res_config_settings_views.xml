<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_config_settings_view_form_addressable" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.addressable</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//app[@name='general_settings']" position="inside">
                <block title="Addressable Autocomplete" id="addressable_settings">
                    <setting
                        string="Addressable API Key"
                        help="Required. A free tier is available — sign up at addressable.dev to get a key."
                        documentation="https://www.addressable.dev"
                    >
                        <field name="addressable_api_key" password="True" />
                    </setting>
                    <setting
                        string="Default Country Code"
                        help="Two-letter code (nz, au, se…) used when a contact has no country set."
                    >
                        <field name="addressable_default_country" />
                    </setting>
                    <setting
                        string="API Base URL"
                        help="Leave as default unless using a staging or self-hosted endpoint."
                    >
                        <field name="addressable_base_url" />
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
