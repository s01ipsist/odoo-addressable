<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_config_settings_view_form_addressable" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.addressable</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div
                    class="app_settings_block"
                    data-string="Addressable"
                    string="Addressable"
                    data-key="addressable_autocomplete"
                >
                    <h2>Addressable Autocomplete</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="addressable_api_key" string="API Key" />
                                <div class="text-muted">
                                    Required. A free tier is available —
                                    <a
                                        href="https://www.addressable.dev"
                                        target="_blank"
                                    >sign up at addressable.dev</a>
                                    to get a key.
                                </div>
                                <field name="addressable_api_key" password="True" />
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label
                                    for="addressable_default_country"
                                    string="Default Country Code"
                                />
                                <div class="text-muted">
                                    Two-letter code (nz, au, se…) used when a
                                    contact has no country set.
                                </div>
                                <field name="addressable_default_country" />
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label
                                    for="addressable_base_url"
                                    string="API Base URL"
                                />
                                <div class="text-muted">
                                    Leave as default unless using a staging or
                                    self-hosted endpoint.
                                </div>
                                <field name="addressable_base_url" />
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
