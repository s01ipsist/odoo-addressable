<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!--
        Swap the plain char widget on the partner's main `street` field for the
        Addressable autocomplete widget. The child-address subview uses its own
        `street` field; extend that separately if you want autocomplete there too.
    -->
    <record id="view_partner_form_addressable" model="ir.ui.view">
        <field name="name">res.partner.form.addressable.autocomplete</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <xpath
                expr="//field[@name='street'][1]"
                position="attributes"
            >
                <attribute name="widget">addressable_autocomplete</attribute>
            </xpath>
            <!--
                partner_latitude / partner_longitude are Float fields on
                res.partner (in `base`). They must be present in the view for the
                widget's record.update() to persist them. Read-only, and shown
                only once populated so empty contacts stay uncluttered.
            -->
            <xpath expr="//field[@name='country_id'][1]" position="after">
                <field
                    name="partner_latitude"
                    readonly="1"
                    invisible="partner_latitude == 0.0 and partner_longitude == 0.0"
                />
                <field
                    name="partner_longitude"
                    readonly="1"
                    invisible="partner_latitude == 0.0 and partner_longitude == 0.0"
                />
            </xpath>
        </field>
    </record>
</odoo>
