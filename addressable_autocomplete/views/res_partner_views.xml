<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!--
        Swap the plain char widget on the partner's main `street` field for the
        Addressable autocomplete widget. The child-address subview uses its own
        `street` field; extend that separately if you want autocomplete there too.
    -->
    <record id="view_partner_form_addressable" model="ir.ui.view">
        <field name="name">res.partner.form.addressable.autocomplete</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <xpath
                expr="//field[@name='street'][1]"
                position="attributes"
            >
                <attribute name="widget">addressable_autocomplete</attribute>
            </xpath>
        </field>
    </record>
</odoo>
